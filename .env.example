# MoneyMap AI — environment variables
# Copy this file to .env and fill in your keys.

# ── FRED (Federal Reserve Economic Data) ─────────────────────────────────────
# Required for macro indicators (rates, CPI, unemployment, yield curve).
# Get a free key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=b2114f715036a754011c7efbc1b2191

# ── Alpha Vantage ─────────────────────────────────────────────────────────────
# Required for equity data (daily adjusted prices, quotes, treasury yields).
# Get a free key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=OW2ZS0XVJBEVGW27

# ── BLS (Bureau of Labor Statistics) ─────────────────────────────────────────
# Optional — increases rate limits for CPI and employment data.
# Register at: https://data.bls.gov/registrationEngine/
BLS_API_KEY=aa8d72644eb14aa8abf1d87a016340ca

# ── App settings (optional) ───────────────────────────────────────────────────
# MONEYMAP_ENV=development
# MONEYMAP_LOG_LEVEL=INFO
